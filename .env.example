# Root environment variables for local development.
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is already listed in .gitignore.
#
# For production, set these in the Vercel dashboard:
#   Project → Settings → Environment Variables
#
# These are server-side only — read by api/contact.js at runtime.
# They are NEVER bundled into the browser build.

# Your Resend API key — from resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The inbox that receives portfolio contact messages
TO_EMAIL=kuwalisean5@gmail.com

# A verified sender in your Resend account.
# For testing use: onboarding@resend.dev
FROM_EMAIL=portfolio@yourdomain.com

# Your Vercel deployment URL — restricts which origins the function accepts.
# Example: https://sean-kuwali.vercel.app
# For local dev this can be * or http://localhost:3000
ALLOWED_ORIGIN=https://yoursite.vercel.app
